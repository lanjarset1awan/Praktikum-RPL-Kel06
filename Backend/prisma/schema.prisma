// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now()) 

  // RELASI
  reports   Report[]
}

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  category    String   // urgent / normal (atau kamu bisa expand nanti)
  location    String
  description String
  photo       String?  // optional (URL / path)
  status      String @default("pending")
  createdAt   DateTime @default(now())

  // RELASI KE USER
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}